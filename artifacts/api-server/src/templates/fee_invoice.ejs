<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UPRISER Fee Invoice</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', 'Trebuchet MS', sans-serif;
            background: white;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            min-height: 100vh;
            padding: 20px;
        }

        .invoice-container {
            width: 100%;
            max-width: 780px;
            background: white;
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0,0,0,0.12);
            display: flex;
            flex-direction: column;
        }

        /* ── HEADER ── */
        .header-section {
            flex: 0 0 auto;
            padding: 14px 24px 14px 18px;
            background: linear-gradient(90deg, #1e3c72 0%, #2a5298 100%);
            color: white;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .header-brand {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-wrap img {
            height: 56px;
            width: 56px;
            object-fit: contain;
            border-radius: 6px;
            display: block;
        }

        .header-text h1 {
            font-size: 17px;
            font-weight: 700;
            letter-spacing: 0.4px;
            line-height: 1.2;
        }

        .header-text p {
            font-size: 10.5px;
            opacity: 0.85;
            font-style: italic;
            margin-top: 3px;
        }

        .invoice-meta {
            text-align: right;
            font-size: 10.5px;
            line-height: 1.6;
            white-space: nowrap;
        }

        .invoice-meta strong {
            display: block;
            font-size: 13px;
            letter-spacing: 0.5px;
            margin-bottom: 2px;
        }

        /* ── BODY ── */
        .body-section {
            flex: 1;
            padding: 18px 24px;
            display: flex;
            gap: 36px;
        }

        .student-section, .fee-section {
            flex: 1;
            font-size: 11.5px;
        }

        .section-title {
            font-weight: 700;
            font-size: 12px;
            margin-bottom: 9px;
            color: #1e3c72;
            border-bottom: 2px solid #2a5298;
            padding-bottom: 4px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .info-row {
            display: flex;
            margin-bottom: 6px;
            gap: 10px;
        }

        .info-label {
            font-weight: 600;
            color: #444;
            min-width: 60px;
        }

        .info-value { color: #555; flex: 1; }

        .fee-item {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
            border-bottom: 1px dotted #ddd;
            margin-bottom: 8px;
        }

        .fee-desc { color: #333; font-weight: 500; }

        .fee-amount { color: #1e3c72; font-weight: 700; }

        .total-due {
            display: flex;
            justify-content: space-between;
            margin-top: 10px;
            padding-top: 8px;
            border-top: 2px solid #1e3c72;
            font-weight: 700;
            font-size: 13px;
            color: #1e3c72;
        }

        /* ── STATUS BADGE ── */
        .status-badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .status-unpaid  { background: #fff3cd; color: #856404; }
        .status-paid    { background: #d1e7dd; color: #0a3622; }
        .status-overdue { background: #f8d7da; color: #842029; }

        /* ── FOOTER ── */
        .footer-section {
            background: #f8f9fa;
            padding: 10px 24px;
            font-size: 9.5px;
            color: #666;
            border-top: 1px solid #ddd;
            text-align: center;
        }

        @media (max-width: 640px) {
            .invoice-container { height: auto; }
            .body-section { flex-direction: column; gap: 12px; }
        }
    </style>
</head>
<body>
<div class="invoice-container">

    <!-- HEADER -->
    <div class="header-section">
        <div class="header-brand">
            <div class="logo-wrap">
                <img src="<%- logoBase64 %>" alt="UPRISER Logo">
            </div>
            <div class="header-text">
                <h1>UPRISER: INSTITUTE OF TECHNOLOGY</h1>
                <p>Education and Beyond...</p>
            </div>
        </div>
        <div class="invoice-meta">
            <strong>Fee Invoice</strong>
            <div>No: <%= invoiceNumber %></div>
            <div>Date: <%= issuedDate %></div>
            <div>Due: <%= dueDate %></div>
        </div>
    </div>

    <!-- BODY -->
    <div class="body-section">
        <!-- Student Details -->
        <div class="student-section">
            <div class="section-title">Student Details</div>
            <div class="info-row">
                <span class="info-label">Name:</span>
                <span class="info-value"><%= studentName %></span>
            </div>
            <div class="info-row">
                <span class="info-label">ID:</span>
                <span class="info-value"><%= studentId %></span>
            </div>
            <div class="info-row">
                <span class="info-label">Batch:</span>
                <span class="info-value"><%= batch %></span>
            </div>
            <div class="info-row">
                <span class="info-label">Email:</span>
                <span class="info-value"><%= email %></span>
            </div>
            <div class="info-row">
                <span class="info-label">Status:</span>
                <span class="info-value">
                    <span class="status-badge status-<%= status %>"><%= status %></span>
                </span>
            </div>
        </div>

        <!-- Fee Breakdown -->
        <div class="fee-section">
            <div class="section-title">Fee Breakdown</div>
            <div class="fee-item">
                <span class="fee-desc">Course Fee – C/C++ Algorithms (<%= batch %>)</span>
                <span class="fee-amount">Rs <%= amountFormatted %></span>
            </div>
            <div class="total-due">
                <span>Total Amount Due</span>
                <span>Rs <%= amountFormatted %> /-</span>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <div class="footer-section">
        Thank you for your enrollment with UPRISER: INSTITUTE OF TECHNOLOGY &nbsp;|&nbsp;
        For inquiries: admin@iiecs.edu &nbsp;|&nbsp;
        This is a computer-generated invoice. No signature required.
    </div>

</div>
</body>
</html>
