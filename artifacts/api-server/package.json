{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "LD_LIBRARY_PATH=../../libs:$LD_LIBRARY_PATH node --enable-source-maps --env-file=../../.env ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@swc/helpers": "^0.5.15",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^3.6.0",
    "drizzle-orm": "catalog:",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "nodemailer": "^8.0.10",
    "pdfkit": "^0.17.2",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "puppeteer": "^25.1.0",
    "puppeteer-core": "^25.1.0",
    "sib-api-v3-sdk": "^8.5.0",
    "@supabase/supabase-js": "^2.107.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.13.9",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0"
  }
}
